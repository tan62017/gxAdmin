{
  "compilerOptions": {
    "checkJs": false,
    "target": "es2017",
    "module": "commonjs",
    "removeComments": false,
    "preserveConstEnums": true,
    "moduleResolution": "node",
    "experimentalDecorators": true,
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "outDir": "lib",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strictNullChecks": true,
    "sourceMap": true,
    "baseUrl": ".",
    "rootDir": ".",
    "jsx": "preserve",
    "allowJs": true,
    "resolveJsonModule": true,
    "typeRoots": [
      "node_modules/@types"
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@utils/*": ["./src/utils/*"],
      "@components/*": ["./src/components/*"],
      "@assets/*": ["./src/assets/*"],
      "@router/*": ["./src/router/*"],
      "@store/*": ["./src/store/*"],
      "@api/*": ["./src/api/*"],
      "@views/*": ["./src/views/*"],
      "@config/*": ["./src/config/*"],
    }
  },
  "include": ["./src", "./types", "./auto-imports.d.ts", "components.d.ts", "@tonyptang/store-helper/vuex"],
	"vueCompilerOptions": {
		"experimentalDisableTemplateSupport": true
	},
  "compileOnSave": false
}